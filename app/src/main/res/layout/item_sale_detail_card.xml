<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/textProductName" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="15sp" android:textStyle="bold" android:textColor="?android:textColorPrimary" />
            <TextView android:id="@+id/textTime" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/grey_medium" />
        </LinearLayout>
        <TextView android:id="@+id/textProductAttrs" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textColor="@color/grey_medium" android:layout_marginTop="2dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="4dp">
            <TextView android:id="@+id/textQuantity" android:layout_width="0dp"
                android:layout_weight="1" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="@color/grey_medium" />
            <TextView android:id="@+id/textAmount" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="15sp"
                android:textStyle="bold" android:textColor="@color/primary" />
        </LinearLayout>
        <TextView android:id="@+id/textProfit" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp"
            android:textColor="@color/green" android:layout_marginTop="2dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
