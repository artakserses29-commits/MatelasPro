<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:minHeight="?attr/actionBarSize"
        app:title="Gestion ALU"
        app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/white">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp">
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardListesProduits"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardElevation="4dp" app:cardCornerRadius="12dp" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_package" android:tint="@color/primary" android:contentDescription="Produits" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Listes Produits" android:textSize="18sp" android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gérer les produits ALU" android:textSize="14sp" android:textColor="@color/grey_medium" />
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play" android:tint="@color/grey_medium" android:contentDescription="Go" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNote"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardElevation="4dp" app:cardCornerRadius="12dp" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_document" android:tint="@color/primary" android:contentDescription="Note" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Note" android:textSize="18sp" android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Prendre des notes" android:textSize="14sp" android:textColor="@color/grey_medium" />
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play" android:tint="@color/grey_medium" android:contentDescription="Go" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDevis"
                android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardElevation="4dp" app:cardCornerRadius="12dp" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_devis" android:tint="@color/primary" android:contentDescription="Devis" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Devis" android:textSize="18sp" android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Créer des devis" android:textSize="14sp" android:textColor="@color/grey_medium" />
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play" android:tint="@color/grey_medium" android:contentDescription="Go" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDevisEnregistres"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardElevation="4dp" app:cardCornerRadius="12dp" android:foreground="?attr/selectableItemBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <ImageView android:layout_width="48dp" android:layout_height="48dp" android:src="@drawable/ic_folder" android:tint="@color/primary" android:contentDescription="Devis enregistrés" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Devis enregistrés" android:textSize="18sp" android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Consulter les devis sauvegardés" android:textSize="14sp" android:textColor="@color/grey_medium" />
                    </LinearLayout>
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_media_play" android:tint="@color/grey_medium" android:contentDescription="Go" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
        <include layout="@layout/shimmer_card_skeleton" android:id="@+id/skeleton" />
        </FrameLayout>
    </ScrollView>
    </LinearLayout>
</FrameLayout>
