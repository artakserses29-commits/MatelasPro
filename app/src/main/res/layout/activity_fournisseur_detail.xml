<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/grey_light">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/primary" android:minHeight="?attr/actionBarSize"
        app:title="Fournisseur" app:titleTextColor="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/white">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
    </com.google.android.material.appbar.MaterialToolbar>
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
                android:layout_height="wrap_content" app:cardElevation="3dp" app:cardCornerRadius="14dp"
                app:contentPadding="14dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView android:id="@+id/textFournisseurName" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textSize="18sp"
                        android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:textSize="14sp" android:textColor="?android:textColorPrimary"
                            android:text="Reste" />
                        <TextView android:id="@+id/textReste" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="?android:textColorPrimary" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="12dp">
                        <Button android:id="@+id/btnAjouterProduit" android:layout_width="0dp"
                            android:layout_height="42dp" android:layout_weight="1" android:text="+ Produit"
                            android:layout_marginEnd="4dp" android:backgroundTint="@color/primary"
                            android:textColor="@color/white" />
                        <Button android:id="@+id/btnPayer" android:layout_width="0dp"
                            android:layout_height="42dp" android:layout_weight="1" android:text=" Payer"
                            android:layout_marginStart="4dp" android:backgroundTint="@color/green"
                            android:textColor="@color/white" android:drawableStart="@android:drawable/ic_input_add" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Historique" android:textSize="14sp" android:textStyle="bold"
                android:textColor="?android:textColorPrimary" android:layout_marginTop="12dp" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerHistory"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
            <TextView android:id="@+id/textEmptyHistory" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="Aucun historique"
                android:textSize="13sp" android:textColor="@color/grey_medium"
                android:gravity="center" android:padding="8dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
