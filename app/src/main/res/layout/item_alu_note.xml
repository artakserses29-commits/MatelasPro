<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardElevation="3dp" app:cardCornerRadius="14dp"
    app:contentPadding="14dp" android:foreground="?attr/selectableItemBackground">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:id="@+id/textClientName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="16sp"
            android:textStyle="bold" android:textColor="?android:textColorPrimary" />
        <TextView android:id="@+id/textDescription" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="13sp"
            android:textColor="@color/grey_medium" android:layout_marginTop="2dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="13sp" android:textColor="?android:textColorPrimary"
                android:text="Total: " />
            <TextView android:id="@+id/textMontantTotal" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="13sp" android:textColor="?android:textColorPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="@color/green" android:text="Payé: " />
            <TextView android:id="@+id/textMontantPaye" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/green" android:layout_marginEnd="12dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="@color/red" android:text="Reste: " />
            <TextView android:id="@+id/textReste" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/red" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
