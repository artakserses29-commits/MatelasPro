<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/skeleton"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="visible">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <View android:layout_width="match_parent" android:layout_height="90dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="10dp" />
        <View android:layout_width="match_parent" android:layout_height="90dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="10dp" />
        <View android:layout_width="match_parent" android:layout_height="90dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="10dp" />
        <View android:layout_width="match_parent" android:layout_height="90dp"
            android:background="@drawable/skeleton_rect" />
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>
