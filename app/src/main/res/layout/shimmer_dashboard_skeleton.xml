<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skeleton"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="visible">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <View android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/skeleton_rect" />
            <View android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/skeleton_rect" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="12dp" />
        <View android:layout_width="160dp" android:layout_height="14dp"
            android:background="@drawable/skeleton_rect" android:layout_marginTop="4dp" android:layout_marginBottom="6dp" />
        <View android:layout_width="match_parent" android:layout_height="120dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="12dp" />
        <View android:layout_width="160dp" android:layout_height="14dp"
            android:background="@drawable/skeleton_rect" android:layout_marginBottom="6dp" />
        <View android:layout_width="match_parent" android:layout_height="120dp"
            android:background="@drawable/skeleton_rect" />
    </LinearLayout>
</com.facebook.shimmer.ShimmerFrameLayout>
