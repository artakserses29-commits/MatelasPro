<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:minHeight="?attr/actionBarSize"
        app:title="Ventes"
        app:titleTextColor="?attr/colorOnPrimary"
        app:navigationIcon="@android:drawable/ic_menu_revert">
        <android.widget.Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </com.google.android.material.appbar.MaterialToolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row: Aujourd'hui + Ce mois -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardToday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#E8F5E9">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Aujourd'hui" android:textSize="12sp" android:textColor="@color/grey_medium" />
                        <TextView android:id="@+id/textTodaySales" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0,00 MGA" android:textSize="16sp"
                            android:textStyle="bold" android:textColor="@color/primary" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMonth"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardElevation="3dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#E3F2FD">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ce mois" android:textSize="12sp" android:textColor="@color/grey_medium" />
                        <TextView android:id="@+id/textMonthSales" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0,00 MGA" android:textSize="16sp"
                            android:textStyle="bold" android:textColor="@color/primary" android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Section: Ventes par jour (7 derniers jours) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ventes par jour (7 derniers jours)" android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/primary_dark" android:layout_marginTop="8dp" android:layout_marginBottom="4dp" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">
                <LinearLayout android:id="@+id/layoutDailySales" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Chargement..." android:textSize="13sp" android:textColor="@color/grey_medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Ventes par mois (cette année) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ventes par mois (cette année)" android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/primary_dark" android:layout_marginTop="8dp" android:layout_marginBottom="4dp" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="8dp">
                <LinearLayout android:id="@+id/layoutMonthlySales" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Chargement..." android:textSize="13sp" android:textColor="@color/grey_medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
        <include layout="@layout/shimmer_dashboard_skeleton" android:id="@+id/skeleton" />
        </FrameLayout>
    </ScrollView>
    </LinearLayout>
</FrameLayout>
